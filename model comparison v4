        logger.error(f"Enriched CSV not found! Run enrich_low_credibility.py first.")
        return baseline_df
    enriched = pd.read_csv(enriched_csv_path)
    enriched["dataset"] = "enriched"
    logger.info(f"Loaded {len(enriched)} enriched low-credibility sources")
    mbfc_by_source = {}
    for e in mbfc_entries:
        source = e.get("source", "")
        if source:
            mbfc_by_source[source] = e
        if "mediabiasfactcheck.com/" in source:
            slug = source.rstrip("/").split("/")[-1]
            mbfc_by_source[slug] = e
    html_low_cred_dir = os.path.join(os.path.dirname(enriched_csv_path), "html_low_cred")
    saved_html_lookup = {}
    if os.path.exists(html_low_cred_dir):
        for f in Path(html_low_cred_dir).glob("*.html"):
            saved_html_lookup[f.stem] = f
        logger.info(f"Found {len(saved_html_lookup)} saved HTML files for CSS re-extraction")
    css_extracted = 0
    new_feature_rows = []
    for _, row in enriched.iterrows():
        new_features = {}
        meta = None
        mbfc_url = row.get("mbfc_review_url", "")
        url = row.get("url", "")
        if mbfc_url:
            meta = mbfc_by_source.get(mbfc_url)
            if not meta:
                slug = mbfc_url.rstrip("/").split("/")[-1] if "/" in str(mbfc_url) else ""
                meta = mbfc_by_source.get(slug)
        new_features.update(extract_mbfc_metadata_features(meta if meta else {}))
        domain = ""
        if pd.notna(url) and url:
            try:
                domain = urlparse(str(url)).netloc.lower().replace("www.", "")
            except:
                domain = str(url).lower()
        new_features.update(extract_domain_ngrams(domain))
        if pd.notna(url) and url and saved_html_lookup:
            try:
                domain_key = urlparse(str(url)).netloc.replace(".", "_")
                html_file = saved_html_lookup.get(domain_key)
                if html_file:
                    html_content = html_file.read_text(encoding="utf-8", errors="replace")
                    temp_extractor = FeatureExtractor(html_content, str(url))
                    css_feats = temp_extractor._css_features()
                    new_features.update(css_feats)
                    css_extracted += 1
            except:
                pass
        new_feature_rows.append(new_features)
    if css_extracted:
        logger.info(f"Re-extracted CSS features from {css_extracted}/{len(enriched)} saved HTML files")
    new_features_df = pd.DataFrame(new_feature_rows)
    enriched = pd.concat([enriched.reset_index(drop=True), new_features_df.reset_index(drop=True)], axis=1)
    logger.info(f"Added MBFC metadata + n-gram + CSS features to enriched data ({len(new_features_df.columns)} new columns)")
    baseline_features = set(baseline_df.columns)
    enriched_features = set(enriched.columns)
    common_features = baseline_features & enriched_features
    logger.info(f"Common features: {len(common_features)}")
    meta_cols = ["credibility_class", "dataset", "source_file", "url",
                 "source_name", "bias_rating", "factual_reporting"]
    numeric_baseline = baseline_df.select_dtypes(include=[np.number]).columns.tolist()
    numeric_enriched = enriched.select_dtypes(include=[np.number]).columns.tolist()
    shared_numeric = sorted(set(numeric_baseline) & set(numeric_enriched))
    logger.info(f"Shared numeric features for modelling: {len(shared_numeric)}")
    keep_cols = shared_numeric + [c for c in meta_cols if c in baseline_df.columns or c in enriched.columns]
    combined = pd.concat(
        [baseline_df.reindex(columns=keep_cols), enriched.reindex(columns=keep_cols)],
        ignore_index=True,
    )
    for col in shared_numeric:
        combined[col] = combined[col].fillna(0)
    logger.info(f"\nEnriched dataset total: {len(combined)}")
    dist = Counter(combined["credibility_class"])
    for cls, count in dist.most_common():
        logger.info(f"  {cls}: {count}")
    return combined


def get_feature_columns(df):
    exclude = {"credibility_class", "dataset", "source_file", "url",
               "source_name", "bias_rating", "factual_reporting",
               "final_url", "scrape_status", "url_method",
               "extraction_method", "mbfc_review_url"}
    return [c for c in df.select_dtypes(include=[np.number]).columns if c not in exclude]


def engineer_features(df, feature_cols):
    df = df.copy()
    new_cols = []
    def safe_div(a, b, default=0):
        return np.where(b > 0, a / b, default)
    if "num_scripts" in df.columns and "total_tags" in df.columns:
        df["ratio_scripts_per_tag"] = safe_div(df["num_scripts"], df["total_tags"])
        new_cols.append("ratio_scripts_per_tag")
    if "num_iframes" in df.columns and "total_tags" in df.columns:
        df["ratio_iframes_per_tag"] = safe_div(df["num_iframes"], df["total_tags"])
        new_cols.append("ratio_iframes_per_tag")
    if "ad_keyword_count" in df.columns and "num_paragraphs" in df.columns:
        df["ratio_ads_per_paragraph"] = safe_div(df["ad_keyword_count"], df["num_paragraphs"])
        new_cols.append("ratio_ads_per_paragraph")
    if "num_links_external" in df.columns and "num_links_total" in df.columns:
        df["ratio_external_links"] = safe_div(df["num_links_external"], df["num_links_total"])
        new_cols.append("ratio_external_links")
    if "num_links_empty" in df.columns and "num_links_total" in df.columns:
        df["ratio_empty_links"] = safe_div(df["num_links_empty"], df["num_links_total"])
        new_cols.append("ratio_empty_links")
    if "inline_script_count" in df.columns and "num_scripts" in df.columns:
        df["ratio_inline_scripts"] = safe_div(df["inline_script_count"], df["num_scripts"].clip(lower=1))
        new_cols.append("ratio_inline_scripts")
    if "num_headings" in df.columns and "num_paragraphs" in df.columns:
        df["ratio_headings_per_paragraph"] = safe_div(df["num_headings"], df["num_paragraphs"])
        new_cols.append("ratio_headings_per_paragraph")
    if "num_images" in df.columns and "word_count" in df.columns:
        df["ratio_images_per_1k_words"] = safe_div(df["num_images"] * 1000, df["word_count"])
        new_cols.append("ratio_images_per_1k_words")
    if "third_party_script_domains" in df.columns and "num_scripts" in df.columns:
        df["ratio_third_party_scripts"] = safe_div(df["third_party_script_domains"], df["num_scripts"].clip(lower=1))
        new_cols.append("ratio_third_party_scripts")
    if "popup_indicator_count" in df.columns and "total_tags" in df.columns:
        df["ratio_popups_per_tag"] = safe_div(df["popup_indicator_count"], df["total_tags"])
        new_cols.append("ratio_popups_per_tag")
    if "ad_keyword_count" in df.columns and "hidden_element_count" in df.columns:
        df["interact_ads_x_hidden"] = df["ad_keyword_count"] * df["hidden_element_count"]
        new_cols.append("interact_ads_x_hidden")
    if "num_scripts" in df.columns and "third_party_script_domains" in df.columns:
        df["interact_scripts_x_3rdparty"] = df["num_scripts"] * df["third_party_script_domains"]
        new_cols.append("interact_scripts_x_3rdparty")
    if "text_to_html_ratio" in df.columns and "ad_keyword_count" in df.columns:
        df["interact_low_text_high_ads"] = (1 - df["text_to_html_ratio"].clip(upper=1)) * df["ad_keyword_count"]
        new_cols.append("interact_low_text_high_ads")
    if "popup_indicator_count" in df.columns and "num_iframes" in df.columns:
        df["interact_popups_x_iframes"] = df["popup_indicator_count"] * df["num_iframes"]
        new_cols.append("interact_popups_x_iframes")
    if "num_links_external" in df.columns and "num_links_empty" in df.columns:
        df["interact_external_x_empty_links"] = df["num_links_external"] * df["num_links_empty"]
        new_cols.append("interact_external_x_empty_links")
    clickbait_cols = ["clickbait_allcaps_headlines", "clickbait_exclamation_headlines", "clickbait_question_headlines"]
    if all(c in df.columns for c in clickbait_cols):
        df["clickbait_total"] = df[clickbait_cols].sum(axis=1)
        new_cols.append("clickbait_total")
        if "text_to_html_ratio" in df.columns:
            df["interact_clickbait_x_low_text"] = df["clickbait_total"] * (1 - df["text_to_html_ratio"].clip(upper=1))
            new_cols.append("interact_clickbait_x_low_text")
    trust_cols = ["has_about_page_link", "has_contact_page_link",
                  "has_privacy_policy_link", "has_terms_link",
                  "has_meta_description", "has_og_tags", "has_canonical"]
    available_trust = [c for c in trust_cols if c in df.columns]
    if available_trust:
        df["trust_score"] = df[available_trust].sum(axis=1)
        new_cols.append("trust_score")
    if all(c in df.columns for c in ["ad_keyword_count", "popup_indicator_count",
                                      "hidden_element_count", "num_links_empty"]):
        df["deception_score"] = (
            df["ad_keyword_count"].clip(upper=20) / 20 * 0.3 +
            df["popup_indicator_count"].clip(upper=20) / 20 * 0.25 +
            df["hidden_element_count"].clip(upper=20) / 20 * 0.25 +
            df["num_links_empty"].clip(upper=50) / 50 * 0.2
        )
        new_cols.append("deception_score")
    if "trust_score" in df.columns and "deception_score" in df.columns:
        df["trust_deception_ratio"] = safe_div(df["trust_score"], df["deception_score"].clip(lower=0.01))
        new_cols.append("trust_deception_ratio")
    if all(c in df.columns for c in ["total_tags", "unique_tags", "max_dom_depth"]):
        df["complexity_score"] = (
            np.log1p(df["total_tags"]) * 0.4 +
            df["unique_tags"] * 0.3 +
            df["max_dom_depth"] * 0.3
        )
        new_cols.append("complexity_score")
    skewed_candidates = [
        "total_tags", "html_length", "text_length", "word_count",
        "num_links_total", "num_scripts", "num_divs", "num_spans",
        "ad_keyword_count", "sentence_count", "css_total_length",
        "ext_css_size_bytes", "ext_css_num_selectors", "ext_css_num_classes"
    ]
    for col in skewed_candidates:
        if col in df.columns:
            new_name = f"log_{col}"
            df[new_name] = np.log1p(df[col].clip(lower=0))
            new_cols.append(new_name)
    for col in new_cols:
        df[col] = df[col].fillna(0).replace([np.inf, -np.inf], 0)
    updated_feature_cols = feature_cols + new_cols
    logger.info(f"Feature engineering: {len(feature_cols)} -> {len(updated_feature_cols)} features (+{len(new_cols)} derived)")
    return df, updated_feature_cols


