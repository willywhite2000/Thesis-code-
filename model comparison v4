# *** NEW ***  McNemar's test
# =============================================================================
def mcnemar_test(y_true, preds_a, preds_b, with_continuity=True):
    """
    McNemar's test for paired binary correctness from two classifiers.
    Returns: chi2 statistic, p-value, contingency counts (b, c).
        b = A correct, B wrong
        c = A wrong, B correct
    """
    y_true = np.asarray(y_true)
    preds_a = np.asarray(preds_a)
    preds_b = np.asarray(preds_b)
    correct_a = (preds_a == y_true)
    correct_b = (preds_b == y_true)
    b = int(np.sum(correct_a & ~correct_b))
    c = int(np.sum(~correct_a & correct_b))
    if b + c == 0:
        return 0.0, 1.0, b, c
    if with_continuity:
        chi2_stat = (abs(b - c) - 1) ** 2 / (b + c)
    else:
        chi2_stat = (b - c) ** 2 / (b + c)
    p_value = 1 - chi2.cdf(chi2_stat, df=1)
    return float(chi2_stat), float(p_value), b, c


def run_mcnemar_analysis(preds_dir, output_dir):
    """
    Three blocks of comparisons:
      1) Within Baseline: best (XGB_class_weights) vs each alternative
      2) Within Enriched: best (XGB_SMOTE_weights) vs each alternative
      3) Cross-dataset:   best Baseline vs best Enriched on the
                          3779 shared instances (test_idx < 3779 in enriched)
    """
    logger.info(f"\n{'='*80}")
    logger.info(f"McNEMAR'S TEST ANALYSIS")
    logger.info(f"{'='*80}")

    def _load(dataset, model):
        path = os.path.join(preds_dir, f"preds_{dataset}_{model}.csv")
        if not os.path.exists(path):
            logger.warning(f"  Missing predictions file: {path}")
            return None
        df = pd.read_csv(path)
        # one prediction per test_idx (each instance appears once across folds)
        df = df.sort_values("test_idx").reset_index(drop=True)
        return df

    rows = []

    # ---- 1. WITHIN BASELINE ----
    logger.info("\n  [1] Within-Baseline comparisons (vs best: XGB_class_weights)")
    best_baseline = "XGB_class_weights"
    base_best_df = _load("Baseline", best_baseline)
    if base_best_df is not None:
        baseline_models = ["RF_no_balance", "XGB_no_balance", "RF_SMOTE", "XGB_SMOTE",
                           "RF_class_weights", "RF_SMOTE_weights", "XGB_SMOTE_weights",
                           "Stacking_RF_XGB"]
        for m in baseline_models:
            other = _load("Baseline", m)
            if other is None:
                continue
            # Align on test_idx
            merged = base_best_df[["test_idx", "y_true", "y_pred"]].merge(
                other[["test_idx", "y_pred"]], on="test_idx", suffixes=("_best", "_other")
            )
            chi2_v, p, b, c = mcnemar_test(
                merged["y_true"], merged["y_pred_best"], merged["y_pred_other"]
            )
            sig = "***" if p < 0.001 else "**" if p < 0.01 else "*" if p < 0.05 else "ns"
            logger.info(f"    {best_baseline} vs {m:<22s}  chi2={chi2_v:7.3f}  p={p:.4f} {sig}  (b={b}, c={c})")
            rows.append({
                "comparison": f"Baseline: {best_baseline} vs {m}",
                "chi2": chi2_v, "p_value": p, "significance": sig,
                "model_a_correct_only": b, "model_b_correct_only": c,
                "n_compared": len(merged),
            })

    # ---- 2. WITHIN ENRICHED ----
    logger.info("\n  [2] Within-Enriched comparisons (vs best: XGB_SMOTE_weights)")
    best_enriched = "XGB_SMOTE_weights"
    enr_best_df = _load("Enriched", best_enriched)
    if enr_best_df is not None:
        enriched_models = ["RF_no_balance", "XGB_no_balance", "RF_SMOTE", "XGB_SMOTE",
                           "RF_class_weights", "XGB_class_weights", "RF_SMOTE_weights",
                           "Stacking_RF_XGB"]
        for m in enriched_models:
            other = _load("Enriched", m)
            if other is None:
                continue
            merged = enr_best_df[["test_idx", "y_true", "y_pred"]].merge(
                other[["test_idx", "y_pred"]], on="test_idx", suffixes=("_best", "_other")
            )
            chi2_v, p, b, c = mcnemar_test(
                merged["y_true"], merged["y_pred_best"], merged["y_pred_other"]
            )
            sig = "***" if p < 0.001 else "**" if p < 0.01 else "*" if p < 0.05 else "ns"
            logger.info(f"    {best_enriched} vs {m:<22s}  chi2={chi2_v:7.3f}  p={p:.4f} {sig}  (b={b}, c={c})")
            rows.append({
                "comparison": f"Enriched: {best_enriched} vs {m}",
                "chi2": chi2_v, "p_value": p, "significance": sig,
                "model_a_correct_only": b, "model_b_correct_only": c,
                "n_compared": len(merged),
            })

    # ---- 3. CROSS-DATASET on the 3779 shared baseline instances ----
    # Note: in build_enriched_dataset(), baseline rows are concatenated FIRST,
    # so the first 3779 rows of the enriched dataset are the baseline samples.
    # Same row index = same source.
    logger.info("\n  [3] Cross-dataset: best Baseline vs best Enriched on shared instances")
    logger.info("      (first 3779 indices of enriched = baseline samples; out-of-fold preds)")
    if base_best_df is not None and enr_best_df is not None:
        BASELINE_N = 3779
        # Both predict each baseline instance exactly once (out-of-fold)
        base_subset = base_best_df[base_best_df["test_idx"] < BASELINE_N].copy()
        enr_subset = enr_best_df[enr_best_df["test_idx"] < BASELINE_N].copy()
        merged = base_subset[["test_idx", "y_true", "y_pred"]].merge(
            enr_subset[["test_idx", "y_pred"]], on="test_idx", suffixes=("_baseline", "_enriched")
        )
        # Sanity: y_true should match (same instances, same encoder ordering)
        # If not, log it.
        chi2_v, p, b, c = mcnemar_test(
            merged["y_true"], merged["y_pred_baseline"], merged["y_pred_enriched"]
        )
        sig = "***" if p < 0.001 else "**" if p < 0.01 else "*" if p < 0.05 else "ns"
        logger.info(f"    Baseline best vs Enriched best on n={len(merged)} shared instances")
        logger.info(f"    chi2={chi2_v:.3f}  p={p:.6f} {sig}")
        logger.info(f"    Baseline-only correct: {b}   |   Enriched-only correct: {c}")
        logger.info(f"    Net advantage to enrichment: {c - b} additional correct predictions")
        rows.append({
            "comparison": "CROSS: Baseline-best vs Enriched-best (shared 3779)",
            "chi2": chi2_v, "p_value": p, "significance": sig,
            "model_a_correct_only": b, "model_b_correct_only": c,
            "n_compared": len(merged),
        })

        # Also: low-credibility-class-only McNemar on the cross comparison
        # (filter to instances where y_true is the low-credibility class)
        # Need the encoded label for "low credibility": alphabetically it's class 1
        # (high=0, low=1, medium=2). Confirm from class names if available.
        low_label_int = 1  # 'low credibility' alphabetically index 1
        low_subset = merged[merged["y_true"] == low_label_int]
        if len(low_subset) > 0:
            chi2_v, p, b, c = mcnemar_test(
                low_subset["y_true"], low_subset["y_pred_baseline"], low_subset["y_pred_enriched"]
            )
            sig = "***" if p < 0.001 else "**" if p < 0.01 else "*" if p < 0.05 else "ns"
            logger.info(f"\n    Low-credibility subset only (n={len(low_subset)}):")
            logger.info(f"    chi2={chi2_v:.3f}  p={p:.6f} {sig}")
            logger.info(f"    Baseline-only correct: {b}  |  Enriched-only correct: {c}")
            rows.append({
                "comparison": "CROSS (LOW class only): Baseline-best vs Enriched-best",
                "chi2": chi2_v, "p_value": p, "significance": sig,
                "model_a_correct_only": b, "model_b_correct_only": c,
                "n_compared": len(low_subset),
            })

    # Save table
    if rows:
        out_df = pd.DataFrame(rows)
        out_path = os.path.join(output_dir, "mcnemar_results.csv")
        out_df.to_csv(out_path, index=False)
        logger.info(f"\n  Saved McNemar results to: {out_path}")

    return rows


